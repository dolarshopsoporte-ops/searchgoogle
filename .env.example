# Database (Neon)
DATABASE_URL=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Initial user (seeded on first boot if no User exists)
BOOTSTRAP_USER_EMAIL=
BOOTSTRAP_USER_PASSWORD=

# Apify — busca no Google
# Token da conta Apify (apify.com/account/integrations)
APIFY_TOKEN=
# ID do actor Apify usado para rodar a busca (ex: "apify~google-search-scraper"
# ou o ID de um actor customizado). Preencher antes do deploy.
APIFY_SEARCH_ACTOR_ID=
